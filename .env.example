# --- SQLite (default local) ---
# Path is relative to this app when you run from romainRetreatCMS/.
DATABASE_URL=file:../romainRetreatServer/data/payload.db
# If DATABASE_URL is accidentally a postgres URL, force file DB:
# PAYLOAD_DB_DRIVER=sqlite

# --- Local Postgres (optional) ---
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/payload_dev?sslmode=disable
# Do not set RDS_IAM_AUTH locally unless you mean it (Lambda sets it). For IAM tests from your machine: RDS_IAM_AUTH_ALLOW_LOCAL=1

PAYLOAD_SECRET=replace-with-a-long-random-string

# Admin / Next app URL (default port 3001).
PAYLOAD_PUBLIC_SERVER_URL=http://127.0.0.1:3001

# GraphQL is served by romainRetreatServer (:3002). Set to true so this Next app does not expose /api/graphql.
PAYLOAD_DISABLE_GRAPHQL=true

# Dev server runs on port 3001 (see package.json) so the web app can use 3000.
# GraphQL (romainRetreatServer): POST http://127.0.0.1:3002/api/graphql
# GraphQL Playground (dev): http://127.0.0.1:3002/api/graphql-playground
