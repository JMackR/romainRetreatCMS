# After `cd ../romainRetreatServer && yarn db:start`, match user/password/db from that script:
# postgresql://payload:payload@127.0.0.1:5432/payload
DATABASE_URL=postgresql://payload:payload@127.0.0.1:5432/payload
PAYLOAD_SECRET=YOUR_SECRET_HERE

# First-time local: let Payload/Drizzle create tables. Set 0 (or remove) in steady-state prod.
PAYLOAD_DATABASE_PUSH=1

# This Next.js / Payload app (used for non-browser fallbacks in Apollo env helper)
PAYLOAD_SERVER_URL=http://localhost:3000

# —— romainRetreatServer (port 3002) — used by `next.config.mjs` rewrites
# /api/retreat-graphql in the browser is proxied to this host + path (no CORS in dev).
ROMAIN_RETREAT_SERVER_URL=http://127.0.0.1:3002
# GraphQL path on the server (Apollo, Yoga, or Payload: use `/api/graphql` or `/graphql` to match the server)
ROMAIN_RETREAT_SERVER_GRAPHQL_PATH=/graphql

# Optional: point Apollo at a full public URL instead of the same-origin proxy (e.g. direct to the server with CORS configured, or a CDN/gateway)
# NEXT_PUBLIC_ROMAIN_RETREAT_GRAPHQL_URL=http://127.0.0.1:3002/graphql

# —— Media: AWS S3 (arn:aws:s3:::romain-media) — @payloadcms/storage-s3
# https://github.com/payloadcms/payload/tree/3.x/packages/storage-s3
# Vercel limits the server request body (~4.5MB); the plugin uses clientUploads (browser → S3 with pre-signed URLs) when VERCEL is set, unless you override:
# S3_USE_CLIENT_UPLOADS=1  # force direct uploads (e.g. test S3 from localhost; bucket CORS must allow your origin)
# S3_USE_CLIENT_UPLOADS=0  # server-side only (fails for large files on Vercel)
# On the S3 bucket: CORS must allow GET, PUT, HEAD, POST and AllowedHeaders: ["*"] for your origins (Vercel URL, custom domain, http://localhost:3000).
# On Vercel: add S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, S3_BUCKET, S3_REGION in Project → Settings → Environment Variables.
#
# **Public image URLs (disablePayloadAccessControl: direct S3 URL):** objects must be readable anonymously.
# Recommended: S3 → bucket → Permissions → Block public access: allow a *bucket policy* to grant public read (or turn off "Block all public access" if you accept a public site media bucket).
# Add a bucket policy (replace bucket name):
#   { "Version": "2012-10-17", "Statement": [ { "Sid": "PublicRead", "Effect": "Allow", "Principal": "*", "Action": "s3:GetObject", "Resource": "arn:aws:s3:::romain-media/*" } ] }
# Optional: if the bucket still uses ACLs, set S3_OBJECT_ACL=public-read so new uploads are public-read (not needed if the bucket policy already allows GetObject for *).
# S3_OBJECT_ACL=public-read
S3_BUCKET=romain-media
S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_KEY_PREFIX=
# S3_PUBLIC_BASE_URL=https://d1111111.cloudfront.net
# NEXT_PUBLIC_S3_MEDIA_HOSTNAME=d1111111.cloudfront.net
