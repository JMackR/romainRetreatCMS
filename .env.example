# SQLite (default for local dev). Match DATABASE_URL in payload.config / db adapter.
DATABASE_URL=file:./romainRetreatCMS.db
PAYLOAD_SECRET=replace-with-a-long-random-string

# Dev server runs on port 3001 (see package.json) so the web app can use 3000.
# GraphQL: POST http://127.0.0.1:3001/api/graphql (prefer 127.0.0.1 for tooling that resolves localhost to IPv6)
# GraphQL Playground (dev): http://127.0.0.1:3001/api/graphql-playground
