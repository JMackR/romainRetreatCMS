{
  "name": "romainRetreatCMS",
  "version": "1.0.0",
  "description": "Romain Retreat — Payload website template + Postgres, GraphQL, Apollo, Tailwind, shadcn",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs 2>/dev/null || true",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "db:push": "cross-env NODE_OPTIONS=--no-deprecation PAYLOAD_DATABASE_PUSH=1 tsx scripts/sync-postgres.mts",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "seed:posts": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed-posts.mts",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.1",
    "lucide-react": "^0.507.0",
    "next": "15.4.11",
    "next-sitemap": "^4.2.3",
    "payload": "3.84.1",
    "prism-react-renderer": "^2.3.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/escape-html": "^1.0.2",
    "@types/node": "^20.11.25",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.4.11",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.7.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
